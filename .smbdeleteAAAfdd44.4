#!/bin/bash
# ─────────────────────────────────────────────────────────────────────────────
# Frigate Native — build script
#
# Compiles the Objective-C source into a double-clickable .app bundle.
# Run this ONCE on your Snow Leopard Mac; the resulting .app can be
# copied anywhere and double-clicked without any dependencies.
#
# Requirements:
#   - Xcode 3.2 (or later) with Command Line Tools installed
#     (MacPorts already requires this, so you should be good)
#
# Usage:
#   cd /path/to/FrigateNative
#   chmod +x build.sh
#   ./build.sh
# ─────────────────────────────────────────────────────────────────────────────

set -e
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
APP_NAME="Frigate Native"
BINARY="FrigateNative"
APP_BUNDLE="$SCRIPT_DIR/$APP_NAME.app"

echo ""
echo "╔══════════════════════════════════════╗"
echo "║   Frigate Native — Build Script      ║"
echo "╚══════════════════════════════════════╝"
echo ""

# ── Find a compiler ───────────────────────────────────────────────────────────
find_compiler() {
    # Prefer clang (better blocks support); fall back to gcc
    for CC_CANDIDATE in \
        /Developer/usr/bin/clang \
        /usr/bin/clang \
        /opt/local/bin/clang \
        /Developer/usr/bin/gcc \
        /usr/bin/gcc-4.2 \
        /usr/bin/gcc \
        /opt/local/bin/gcc; do
        if [ -x "$CC_CANDIDATE" ]; then
            echo "$CC_CANDIDATE"
            return 0
        fi
    done
    return 1
}

CC=$(find_compiler) || {
    echo "ERROR: No C compiler found."
    echo ""
    echo "  Install Xcode 3.2 from your Snow Leopard install DVD, then run:"
    echo "    sudo /Developer/Library/uninstall-devtools --mode=all   # if needed"
    echo "    (re-install Xcode)"
    echo ""
    exit 1
}

echo "Compiler : $CC"
echo "Output   : $APP_BUNDLE"
echo ""

# ── Check for Cocoa framework ─────────────────────────────────────────────────
if [ ! -d "/System/Library/Frameworks/Cocoa.framework" ]; then
    echo "ERROR: Cocoa.framework not found."
    echo "  Make sure the full Xcode SDK is installed (not just CLT)."
    exit 1
fi

# ── Create .app bundle structure ──────────────────────────────────────────────
rm -rf "$APP_BUNDLE"
mkdir -p "$APP_BUNDLE/Contents/MacOS"
mkdir -p "$APP_BUNDLE/Contents/Resources"

# ── Compile ───────────────────────────────────────────────────────────────────
echo "Compiling…"

SOURCES="$SCRIPT_DIR/main.m
         $SCRIPT_DIR/AppDelegate.m
         $SCRIPT_DIR/FrigateAPI.m
         $SCRIPT_DIR/SimpleJSON.m"

# Try with clang/blocks flags first; fall back without them
"$CC" \
    -arch x86_64 \
    -mmacosx-version-min=10.6 \
    -framework Cocoa \
    -fblocks \
    -fobjc-exceptions \
    -O2 \
    -o "$APP_BUNDLE/Contents/MacOS/$BINARY" \
    $SOURCES 2>/dev/null \
|| \
"$CC" \
    -arch x86_64 \
    -mmacosx-version-min=10.6 \
    -framework Cocoa \
    -fobjc-exceptions \
    -O2 \
    -o "$APP_BUNDLE/Contents/MacOS/$BINARY" \
    $SOURCES

echo "Compiled OK"

# ── Copy Info.plist ───────────────────────────────────────────────────────────
cp "$SCRIPT_DIR/Info.plist" "$APP_BUNDLE/Contents/Info.plist"

# ── Create PkgInfo ────────────────────────────────────────────────────────────
printf 'APPLFRG' > "$APP_BUNDLE/Contents/PkgInfo"

# ── Done ──────────────────────────────────────────────────────────────────────
echo ""
echo "✓ Build succeeded!"
echo ""
echo "  App: $APP_BUNDLE"
echo ""
echo "  Double-click 'Frigate Native.app' to launch."
echo "  Or from Terminal:  open '$APP_BUNDLE'"
echo ""
